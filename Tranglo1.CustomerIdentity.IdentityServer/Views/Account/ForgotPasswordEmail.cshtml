@model ForgotPasswordEmailViewModel

<div class="row justify-content-center">
    <div class="col-lg-5">
        <div>
            <!-- Logo -->
            <div class="d-flex flex-column mt-5">
                <div class="mt-5 d-flex justify-content-center">
                    <img src="~/assets/images/phase3/check-email-icon.svg" height="80" />
                </div>
            </div>
            <br />
            <div>

                <div class="text-center w-100 m-auto">
                    <h4 class="text-center mt-2 headline-5 mb-3">Request processed</h4>

                    <p class="mt-4 text-center mb-4 body-2">
                        If your email address exists, you will receive a reset email shortly.
                        <br />
                    </p>

                    <div class="body-2">
                        Didn't get the email? Check your spam or junk folder,
                        <br />
                        or try re-entering your email address.
                        <br /><br />
                        Still need help? Contact our 
                        <a href="mailto:partnerships@tranglo.com" class="link-text" style="text-decoration:none;">customer support</a>
                    </div>

                </div>

            </div>
        </div>


        <div class="row mt-3">
            <!--<div class="col-12 text-center">
                <p class="text-muted">Back to <a asp-controller="Account" asp-action="Login" class="text-muted ml-1"><b>Return to login</b></a></p>
            </div> end col -->

            <div class="mt-3 text-center">
                <a asp-controller="Account" asp-action="Login" style="text-decoration: none;">
                    <button class="mdc-button button-text w-75 primary-color custom-button" id="reset-password-button" type="submit">
                        <span class="mdc-button__ripple"></span> Return to login
                    </button>
                </a>
            </div>
        </div>
        <!-- end row -->

    </div> <!-- end col -->
</div>
<!-- end row -->
@*footer*@
<div class="row tranglo-footer">
    <div class="col">
        <div class="row d-flex justify-content-center">
            <div class="col">
                <partial name="_FooterPartial" />
            </div>
        </div>
    </div>
</div>
