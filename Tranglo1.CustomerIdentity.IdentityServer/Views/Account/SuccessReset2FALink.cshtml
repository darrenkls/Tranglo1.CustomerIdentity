<div class="min-vh-100 d-flex align-items-center justify-content-center flex-column">
    <div class="row w-100 justify-content-center">
        <div class="col-lg-5 text-center">
            <div class="margin-b-3">
                <img src="~/assets/images/phase3/check-email-icon.svg" height="80" draggable="false" />
            </div>

            <h4 class="headline-5 mb-3">
                Reset link sent to your email
            </h4>

            <p class="body-2 margin-b-3">
                A reset link has been sent to your registered email address.
                <br />
                Please check your inbox.
            </p>

            <a class="text-decoration-none" asp-controller="Account" asp-action="Login">
                <button class="mdc-button button-text primary-color custom-button" type="submit">
                    <span class="mdc-button__ripple"></span>
                    Return to login
                </button>
            </a>

        </div>
    </div>

    <div class="row tranglo-footer" style="margin-top: 118px;">
        <div class="col">
            <div class="row d-flex justify-content-center">
                <div class="col">
                    <partial name="_FooterPartial" />
                </div>
            </div>
        </div>
    </div>
</div>

@section Script {
    <style>
        button {
            height: 48px !important;
            width: 424px !important;
        }

        /* Class name following based on https://twdofmixms01.tranglo.net:1234/?path=/story/theme-spacing--spacing */
        .margin-b-3 {
            margin-bottom: 2rem !important;
        }
    </style>
}