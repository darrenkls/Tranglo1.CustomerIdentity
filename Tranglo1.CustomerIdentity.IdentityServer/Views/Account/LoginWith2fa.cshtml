@using Tranglo1.CustomerIdentity.IdentityServer.Models.MFA
@model LoginWith2faViewModel

<script>
    gtag('event', 'view_2FA')
</script>

<div class="row vh-100 me-0">
    <div class="col-md-6 d-none d-lg-block ms-0">
        <div class="background-image-tranglo">
            <img src="/assets/images/tranglo-logo-2.svg" class="tranglo-logo" />
            <img src="/assets/images/extra-logo-tranglo-front-screen.svg" class="tranglo-extra-logo" />
        </div>
    </div>
    <div class="col-md d-flex justify-content-center">
        <div class="d-flex align-items-center row w-100">
            <div class="col d-flex justify-content-center">
                <form method="post" name="verifyOtpForm" id="verifyOtpForm">
                    <input type="hidden" id="AuthenticationType" name="AuthenticationType" asp-for="AuthenticationType">
                    <input type="hidden" id="hidden-totp" name="Code" asp-for="Code">

                    <div id="authenticatorVerifyScreen" class="verify-screen" style="display: none;">
                        <div class="d-flex justify-content-center">
                            <div style="max-width: 420px; width: 100%;">
                                <div class="headline-5 center-container margin-b-5">
                                    <i class="fa fa-arrow-left me-3" id="backButton" style="cursor: pointer;"></i>
                                    Two-factor authentication
                                </div>

                                <p class="body-2 center-container margin-b-5">
                                    Enter the 6-digit code from your authenticator app
                                </p>

                                <div class="center-container">
                                    @await Html.PartialAsync("_OtpInputFields", "authenticator")
                                </div>
                                @if (!string.IsNullOrEmpty(Model.Error))
                                {
                                    <div class="center-container">

                                        <div style="color:red" class="body-2">
                                            @Model.Error
                                        </div>
                                    </div>

                                }

                                <button class="mdc-button button-text w-100 primary-color custom-button" style="margin-top: 2rem;" type="submit" id="authenticatorSubmitButton" disabled>
                                    <span class="mdc-button__ripple"></span> Verify
                                </button>

                                <div class="center-container body-2 fw-medium" style="margin-top: 32px;">
                                    Don’t have access to your authenticator device?
                                </div>

                                <div class="center-container d-flex align-items-center my-2 subtitle-2 link-text fw-medium">
                                    <button type="submit"
                                            form="reset2FAForm"
                                            class="center-container link-button subtitle-2 link-text fw-medium">
                                        <i class="fa-regular fa-envelope me-2"></i>
                                        Send 2FA reset link to email
                                    </button>
                                </div>

                                <a asp-controller="Account" asp-action="RedeemRecoveryCode" class="center-container subtitle-2 link-text fw-medium" style="margin-bottom: 32px;">
                                    Use recovery code
                                </a>

                                <div class="contact-container d-flex align-items-start">
                                    <i class="fa-solid fa-circle-info"></i>

                                    <div class="text-container">
                                        <h3 class="m-0 subtitle-2">
                                            Still having issues?
                                        </h3>

                                        <p class="m-0 body-2">
                                            Contact our
                                            <a class="text-decoration-underline" href="mailto:support.team@tranglo.com">
                                                customer support
                                            </a>
                                        </p>
                                    </div>
                                </div>
                            </div>

                        </div>
                        <partial name="_FooterPartial" />
                    </div>

                    <div id="emailOtpVerifyScreen" class="verify-screen" style="display: none;">
                        <div class="center-container" style="margin-bottom:2rem;">
                            <img src="/assets/images/email-otp.svg" />
                        </div>
                        <div class="headline center-container" style="margin-bottom:2rem;">OTP Verification</div>
                        <p class="body-2 center-container" style="margin-bottom: 2rem;">Enter the 6-digit code sent to your email.</p>

                        <div class="center-container">
                            @await Html.PartialAsync("_OtpInputFields", "email")
                        </div>
                        @if (!string.IsNullOrEmpty(Model.Error))
                        {
                            <div class="center-container">

                                <div style="color:red" class="body-2">
                                    @Model.Error
                                </div>
                            </div>

                        }

                        <div class="center-container" style="margin-top: 2rem;">
                            <button class="mdc-button button-text primary-color custom-button w-50" type="submit" id="emailOtpSubmitButton" disabled>
                                <span class="mdc-button__ripple"></span> Verify
                            </button>
                        </div>
                        <div class="center-container body-1" style="margin-top: 2rem;">
                            Didn't receive OTP?
                            <a id="resendLink" asp-controller="Account" asp-action="LoginWith2fa" class="center-container body-1 recovery-link disabled">
                                Resend Code <span id="countdown"></span>
                            </a>
                        </div>

                        <script>
                            document.addEventListener("DOMContentLoaded", function () {
                                let countdownElement = document.getElementById("countdown");
                                let resendLink = document.getElementById("resendLink");
                                let seconds = 60;

                                function updateCountdown() {
                                    if (seconds > 0) {
                                        countdownElement.textContent = `(${seconds}s)`;
                                        resendLink.classList.add("disabled");
                                        seconds--;
                                        setTimeout(updateCountdown, 1000);
                                    } else {
                                        countdownElement.textContent = "";
                                        resendLink.classList.remove("disabled");
                                        resendLink.style.pointerEvents = "auto"; // Enable link clicking
                                    }
                                }

                                // Disable link initially and start countdown
                                resendLink.style.pointerEvents = "none";
                                updateCountdown();
                            });
                        </script>
                    </div>
                </form>

                <form id="reset2FAForm" asp-action="RequestResetMfa" method="POST">
                    @Html.AntiForgeryToken()
                </form>
            </div>
        </div>
    </div>
</div>

@section Script {
    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.3/dist/jquery.validate.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Detect active screen and select relevant elements
            const authenticatorScreen = document.getElementById("authenticatorVerifyScreen");
            const emailOtpScreen = document.getElementById("emailOtpVerifyScreen");
            const authenticatorSubmitButton = document.getElementById("authenticatorSubmitButton");
            const emailOtpSubmitButton = document.getElementById("emailOtpSubmitButton");

            const inputs = Array.from(document.querySelectorAll('.totp-input'));

            function getVisibleInputs() {
                return inputs.filter(input => input.closest("#authenticatorVerifyScreen, #emailOtpVerifyScreen").style.display !== "none");
            }

            function getVisibleSubmitButton() {
                return authenticatorScreen.style.display !== "none" ? authenticatorSubmitButton : emailOtpSubmitButton;
            }

            // Initially disable submit buttons
            authenticatorSubmitButton.disabled = true;
            emailOtpSubmitButton.disabled = true;

            // Function to update button state based on filled inputs
            function updateButtonState() {
                const visibleInputs = getVisibleInputs();
                const submitButton = getVisibleSubmitButton();
                const allFilled = visibleInputs.every(input => input.value.trim() !== '');
                submitButton.disabled = !allFilled;
            }

            // Input focus and navigation
            inputs.forEach((input) => {
                input.addEventListener("input", function () {
                    updateButtonState();
                    if (input.value.length === 1) {
                        const nextInput = document.getElementById(input.dataset.next);
                        if (nextInput) {
                            nextInput.focus();
                        }
                    }
                });

                input.addEventListener("keydown", function (e) {
                    if (e.key === "Backspace" && input.value === "") {
                        const prevInput = document.getElementById(input.dataset.prev);
                        if (prevInput) {
                            prevInput.focus();
                        }
                    }
                });

                input.addEventListener("paste", function (e) {
                    const pasteData = e.clipboardData.getData("text");
                    const visibleInputs = getVisibleInputs();
                    if (pasteData.length === visibleInputs.length) {
                        visibleInputs.forEach((input, i) => {
                            input.value = pasteData[i];
                        });
                        visibleInputs[visibleInputs.length - 1].focus();
                        e.preventDefault();
                        updateButtonState();
                        submitButton.disabled = false;
                    }
                });
            });

            // Combine inputs into hidden field on submit
            const form = document.getElementById("verifyOtpForm");
            form.addEventListener("submit", function (e) {
                const totpCode = getVisibleInputs().map(input => input.value).join('');
                document.getElementById("hidden-totp").value = totpCode;
            });

            // Toggle visibility of screens based on AuthenticationType
            const authenticationType = document.getElementById("AuthenticationType").value;
            if (authenticationType === "1") {
                emailOtpScreen.style.display = "block";
                authenticatorScreen.style.display = "none";
            } else {
                authenticatorScreen.style.display = "block";
                emailOtpScreen.style.display = "none";
            }

            const backButton = document.getElementById("backButton");
            backButton.addEventListener('click', function () {
                window.location.href = '/';
            });
        });
    </script>
    <style>
        .verify-screen {
            display: none;
        }

        .recovery-link {
            color: #16BCEF;
            text-decoration: none;
        }

        .contact-container {
            background: #E1F2FE;
            border-radius: 4px;
            padding: 20px;
            gap: 12px;
        }

            .contact-container i {
                color: #005CB9;
            }

        .text-container, a {
            color: #00488F;
        }

        .link-button {
            background: none;
            border: none;
            border: 0;
        }
    </style>
}
