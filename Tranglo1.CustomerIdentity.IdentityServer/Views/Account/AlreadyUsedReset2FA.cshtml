<div class="row vh-100 me-0">
    <div class="col-md-6 d-sm-none d-xs-none d-lg-block ms-0">
        <div class="background-image-tranglo">
            <img src="/assets/images/tranglo-logo-2.svg" class="tranglo-logo" />
            <img src="/assets/images/extra-logo-tranglo-front-screen.svg" class="tranglo-extra-logo" />
        </div>
    </div>

    <div class="col d-flex flex-column justify-content-center align-items-center" style="max-height: 100vh; overflow: auto;">
        <div class="d-flex flex-column">
            <img src="~/assets/images/phase3/warning-icon.svg" height="64" width="64" class="margin-b-6 mx-auto" draggable="false" />

            <h4 class="color-black text-center headline-5 margin-b-2">
                Reset link already used
            </h4>

            <p class="color-grey-1 text-center body-2 margin-b-3">
                This Two-factor authentication (2FA) reset link has already been used.
                <br />
                Request a new one if you still need to reset.
            </p>

            <div class="text-center">
                <a class="text-decoration-none" asp-controller="Account" asp-action="Login">
                    <button class="mdc-button button-text w-100 primary-color custom-button" id="reset-password-button" type="submit">
                        <span class="mdc-button__ripple"></span> Continue to login
                    </button>
                </a>
            </div>
        </div>

        @* Footer *@
        <div class="row d-flex justify-content-center">
            <div class="col">
                <partial name="_FooterPartial" />
            </div>
        </div>
    </div>
</div>

@section Script {
    <style>
        /* Class name following based on https://twdofmixms01.tranglo.net:1234/?path=/story/theme-spacing--spacing */
        .margin-b-2 {
            margin-bottom: 1.5rem !important;
        }

        .margin-b-3 {
            margin-bottom: 2rem !important;
        }

        .margin-b-6 {
            margin-bottom: 2rem;
        }
    </style>
}