@model CreatePasswordModel
<link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Symbols+Outlined" />
<link rel="stylesheet" href="~/assets/css/tranglo/style.css" asp-append-version="true" />

<div class="row vh-100 me-0">
    <div class="col-md-6 d-sm-none d-xs-none d-lg-block ms-0">
        <div class="background-image-tranglo">
            <img src="/assets/images/tranglo-logo-2.svg" class="tranglo-logo" />
            <img src="/assets/images/extra-logo-tranglo-front-screen.svg" class="tranglo-extra-logo" />
        </div>
    </div>

    <div class="col d-flex flex-column justify-content-center align-items-center" style="max-height: 100vh; overflow: auto;">
        <div class="col-8 mx-auto">
            <div class="d-flex flex-column align-items-center mt-5 mb-3">
                <div class="icon-circle mt-5">
                    <img src="/assets/images/phase3/white-key.svg" alt="Key Icon" class="icon-image" />
                </div>
                <h4 class="text-dark-50 text-center headline-5 mt-3">Set new password</h4>
            </div>

            <form asp-controller="Account" asp-action="CreatePassword">

                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="Token" />


                @* validation error message *@
                @{

                    if (ViewData.ModelState.IsValid == false)
                    {
                        <div class="error-container mb-3" role="alert" id="ErrorAlert">

                            @foreach (var modelState in ViewData.ModelState.Values)
                            {
                                foreach (var error in modelState.Errors)
                                {
                                    @error.ErrorMessage
                                    <br />
                                }
                            }
                        </div>
                    }
                }

                <div class="row">
                    <div class="col-md-12 d-flex justify-content-center">
                        <div class="mdc-text-field mdc-text-field--outlined w-100">
                            <input class="mdc-text-field__input" id="passwordField" type="password" autocomplete="new-password" asp-for="NewPassword">
                            <i id="peekPassword" class="material-symbols-outlined eye-icon">visibility</i>
                            <div class="mdc-notched-outline">
                                <div class="mdc-notched-outline__leading"></div>
                                <div class="mdc-notched-outline__notch">
                                    <label for="passwordField" class="mdc-floating-label">New password</label>
                                </div>
                                <div class="mdc-notched-outline__trailing"></div>
                            </div>
                        </div>                        
                    </div>
                    <div class="col-md-12 ms-2">
                        <span id="passwordErrorbool" class="text-danger" style="display:none"></span>
                        <span id="passwordError" class="text-danger caption"></span>
                    </div>
                </div>
                <div class="row">
                    <div class="col d-flex justify-content-center">
                        <div class="mdc-text-field mdc-text-field--outlined mt-3 w-100">
                            <input class="mdc-text-field__input" id="confirmPasswordField" type="password" autocomplete="off" asp-for="ConfirmPassword">
                            <i id="peekConfirmPassword" class="material-symbols-outlined eye-icon">visibility</i>
                            <div class="mdc-notched-outline">
                                <div class="mdc-notched-outline__leading"></div>
                                <div class="mdc-notched-outline__notch">
                                    <label for="confirmPasswordField" class="mdc-floating-label">Confirm password</label>
                                </div>
                                <div class="mdc-notched-outline__trailing"></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-12 ms-2">
                        <span id="confirmPasswordErrorbool" class="text-danger" style="display:none"></span>
                        <span id="confirmPasswordError" class="text-danger caption"></span>
                    </div>
                </div>

                @* accepted password criteria *@
                <div class="row mt-3 mb-4">
                    <div class="col d-flex justify-content-center w-100">
                        <div class="subtitle-2 password-criteria">
							<ol>
								<li>Minimum 12 characters.</li>
								<li>Must include an uppercase letter, a number, and a special character.</li>
                                <li>Must not reuse the past 6 passwords.</li>
							</ol>
                        </div>
					</div>                                       
                </div>

                @* reset password button *@
                <div class="row">
                    <div class="col d-flex justify-content-center">
                        <button class="mdc-button button-text w-100 primary-color custom-button" id="reset-password-button" type="submit">
                            <span class="mdc-button__ripple"></span> Reset password
                        </button>
                    </div>
                </div>
            </form>
        </div>
        
        @* Return to login *@
        <div class="row mt-3">
            <div class="col-12 text-center">
                <a asp-controller="Account" asp-action="Login" class="subtitle-2 link-text"><b>Return to login</b></a>
            </div>
        </div>
        
        @* Footer *@
        <div class="row d-flex justify-content-center">
            <div class="col">
                <partial name="_FooterPartial" />
            </div>
        </div>
    </div>
</div>

@section script {
    <script src="https://code.jquery.com/jquery-3.5.1.min.js"
            integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0="
            crossorigin="anonymous"></script>
    <script src="~/assets/js/tranglo1/password-validation.js" asp-append-version="true"></script>
    <script src="~/assets/js/tranglo1/password-match.js" asp-append-version="true"></script>
    <script>
        let textFields;

        function resetButtonDisabled(disabled) {
            $('#reset-password-button').attr('disabled', disabled);
        }

        function validatePasswordMatch() {
            const confirmPasswordFieldElement = document.getElementById("confirmPasswordField");
            const confirmPasswordErrorElement = document.getElementById('confirmPasswordError');
            const confirmPasswordWrapper = confirmPasswordFieldElement.closest(".mdc-text-field");
            const confirmPasswordTextField = textFields.find(tf => tf.root === confirmPasswordWrapper);

            const password = $('#passwordField').val();
            const confirmPassword = $('#confirmPasswordField').val();
            const result = checkPasswordMatch(password, confirmPassword);

            if (result && result.ContainError == true) {
                $('#confirmPasswordErrorbool').show();
                confirmPasswordErrorElement.innerHTML = result.message;
                confirmPasswordTextField.input.setCustomValidity(result.message);
                confirmPasswordTextField.valid = false;
                return false;
            }
            else {
                $('#confirmPasswordErrorbool').hide();
                confirmPasswordErrorElement.innerHTML = "";
                confirmPasswordTextField.input.setCustomValidity("");
                confirmPasswordTextField.valid = true;
                return true;
            }
        }

        $(document).ready(function () {
            resetButtonDisabled(true);

            const textFieldElements = document.querySelectorAll('.mdc-text-field');
            textFields = Array.from(textFieldElements).map(el => mdc.textField.MDCTextField.attachTo(el));
            const passwordFieldElement = document.getElementById("passwordField");
            const passwordErrorElement = document.getElementById('passwordError');
            const passwordWrapper = passwordFieldElement.closest(".mdc-text-field");
            const passwordTextField = textFields.find(tf => tf.root === passwordWrapper);
            const peekPassword = document.getElementById('peekPassword');
            const peekConfirmPassword = document.getElementById('peekConfirmPassword');
            const confirmPasswordFieldElement = document.getElementById("confirmPasswordField");
           
            $('#passwordField').on('input', function () {
                const val = $('#passwordField').val();
                const result = validatePassword(val);
                const errors = (result && result.Errors) || [];

                passwordErrorElement.innerHTML = errors.join(', ');

                if (result && result.ContainError == true) {
                    $('#passwordErrorbool').show();
                    passwordErrorElement.innerHTML += " required.";
                    passwordTextField.input.setCustomValidity("Invalid password");
                    passwordTextField.foundation.setValid(false);
                    resetButtonDisabled(true);
                }
                else {
                    $('#passwordErrorbool').hide();
                    passwordTextField.input.setCustomValidity("");
                    passwordTextField.foundation.setValid(true);
                    if(validatePasswordMatch()) {
                        resetButtonDisabled(false);
                    } else {
                        resetButtonDisabled(true);
                    }
                }
            });

            $('#confirmPasswordField').on('input', function () {
                if(validatePasswordMatch() && passwordTextField.valid) {
                    resetButtonDisabled(false);
                } else {
                    resetButtonDisabled(true);
                }
            });

            setupPeekPassword(passwordFieldElement, peekPassword);
            setupPeekPassword(confirmPasswordFieldElement, peekConfirmPassword);
        });

    </script>

    <style>
        .icon-circle {
            width: 64px;
            height: 64px;
            background-color: #1BD1CB;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .icon-image {
            width: 40px;
            height: 40px;
        }

        .password-criteria {
            background-color: #f8f8f8;
            border-radius: 6px;
            padding: 15px;
            width: 100%;
        }

        .password-criteria ol {
            padding-left: 15px;
            margin: 0;
            list-style-position: outside;
        }

        .password-criteria ol li {
            margin-bottom: 1px;
        }
    </style>
}