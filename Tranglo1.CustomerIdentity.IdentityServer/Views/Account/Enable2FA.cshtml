@using Tranglo1.CustomerIdentity.IdentityServer.Models.MFA
@model EnableMultiFactorAuthenticationViewModel

<div class="row vh-100 me-0">
    <div class="col-md-6 d-sm-none d-lg-block ms-0">
        <div class="background-image-tranglo">
            <img src="/assets/images/tranglo-logo-2.svg" class="tranglo-logo" />
            <img src="/assets/images/extra-logo-tranglo-front-screen.svg" class="tranglo-extra-logo" />
        </div>
    </div>
    <div class="col-md d-flex justify-content-center">
        <div class="d-flex align-items-center row w-100">
            <div class="col d-flex justify-content-center">
                <form method="post" name="2faForm" id="2faForm">

                    <input type="hidden" id="currentScreen" name="currentScreen" asp-for="CurrentScreen">
                    <div id="codeSetupScreen" style="display: none;">
                        <div class="headline-5 fw-medium text-center" style="margin-bottom: 1.5rem;">
                            Setup Two-factor authentication app
                        </div>

                        <div class="body-2 text-center" style="margin-bottom: 2rem;">
                            Scan the QR code using Two-factor authenticator app.
                        </div>

                        <div class="center-container">
                            <div id="qrCode" class="qr-code-container"></div>
                            <div id="qrCodeData" data-url="@Html.Raw(@ViewData["AuthenticatorUri"])"></div>
                        </div>

                        <div class="divider body-1">
                            OR
                        </div>

                        <div class="center-container">
                            <div class="subtitle-2" style="margin-bottom: 1.5rem;">
                                Enter the code manually
                            </div>
                        </div>

                        <div class="center-container">
                            <div class="code-display body-2">
                                @ViewData["SharedKey"]
                            </div>
                        </div>

                        <button class="mdc-button button-text w-100 primary-color custom-button" type="button" id="continueButton">
                            <span class="mdc-button__ripple"></span> Continue
                        </button>
                    </div>

                    <div id="verifyOtpScreen" style="display: none;">
                        <div class="d-flex justify-content-center">
                            <div style="max-width: 420px; width: 100%;">
                                <div class="headline-5" style="margin-bottom: 1.5rem;">
                                    <i class="fa fa-arrow-left me-3" style="cursor:pointer;" id="backButton"></i>
                                    Two-factor authentication
                                </div>

                                <div style="margin-bottom: 1.5rem;" class="center-container">
                                    <div class="body-2">
                                        Enter the 6-digit code from your authenticator app
                                    </div>
                                </div>

                                <div class="center-container">
                                    <div class="totp-container">
                                        <input autocomplete="off" type="text" maxlength="1" class="totp-input" id="totp-1" data-next="totp-2">
                                        <input autocomplete="off" type="text" maxlength="1" class="totp-input" id="totp-2" data-next="totp-3" data-prev="totp-1">
                                        <input autocomplete="off" type="text" maxlength="1" class="totp-input" id="totp-3" data-next="totp-4" data-prev="totp-2">
                                        <input autocomplete="off" type="text" maxlength="1" class="totp-input" id="totp-4" data-next="totp-5" data-prev="totp-3">
                                        <input autocomplete="off" type="text" maxlength="1" class="totp-input" id="totp-5" data-next="totp-6" data-prev="totp-4">
                                        <input autocomplete="off" type="text" maxlength="1" class="totp-input" id="totp-6" data-prev="totp-5">
                                    </div>
                                </div>

                                @if (ViewData.ModelState["Code"]?.Errors.Count > 0)
                                {
                                    <div class="caption" style="color:red; margin-top:1rem;">
                                        @foreach (var error in ViewData.ModelState["Code"].Errors)
                                        {
                                            <p>@error.ErrorMessage</p>
                                        }
                                    </div>
                                }

                                <!-- Hidden input to store TOTP code -->
                                <input type="hidden" id="hidden-totp" name="Code" asp-for="Code">

                                <!-- Verify button inside the form -->
                                <button class="mdc-button button-text w-100 primary-color custom-button" type="submit" id="submitButton" style="margin-top: 2.5rem;">
                                    <span class="mdc-button__ripple"></span> Verify
                                </button>

                                <div class="center-container body-2 fw-medium" style="margin-top: 32px;">
                                    Don’t have access to your authenticator device?
                                </div>

                                <div class="center-container d-flex align-items-center mt-2 subtitle-2 link-text fw-medium" style="margin-bottom: 60px;">
                                    <button type="submit"
                                            form="reset2FAForm"
                                            class="center-container link-button subtitle-2 link-text fw-medium">
                                        <i class="fa-regular fa-envelope me-2"></i>
                                        Send 2FA reset link to email
                                    </button>
                                </div>

                                <div class="contact-container d-flex align-items-start">
                                    <i class="fa-solid fa-circle-info"></i>

                                    <div class="text-container" style="color: #00488F;">
                                        <h3 class="m-0 subtitle-2">
                                            Still having issues?
                                        </h3>

                                        <p class="m-0 body-2">
                                            Contact our
                                            <a class="text-decoration-underline" href="mailto:support.team@tranglo.com">
                                                customer support
                                            </a>
                                        </p>
                                    </div>
                                </div>
                            </div>

                        </div>

                        <partial name="_FooterPartial" />
                    </div>
                </form>

                <form id="reset2FAForm" asp-action="RequestResetMfa" method="POST">
                    @Html.AntiForgeryToken()
                </form>
            </div>
        </div>
    </div>
</div>

@section Script {
    <script src="https://code.jquery.com/jquery-3.5.1.min.js" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.3/dist/jquery.validate.js"></script>
    <script src="/assets/js/tranglo1/qr.js"></script>
    <script src="/assets/js/tranglo1/qrcode.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const inputs = document.querySelectorAll('.totp-input');
            const hiddenInput = document.getElementById('hidden-totp');
            const form = document.getElementById('2faForm');
            const submitButton = document.getElementById('submitButton');

            submitButton.disabled = true;

            inputs.forEach(input => {
                input.addEventListener('input', function () {
                    const allFilled = Array.from(inputs).every(input => input.value.trim() !== '');
                    submitButton.disabled = !allFilled;
                });
            });

            inputs.forEach((input, index) => {
                input.addEventListener('input', (e) => {
                    if (e.target.value.length === 1) {
                        const nextInput = document.getElementById(e.target.dataset.next);
                        if (nextInput) {
                            nextInput.focus();
                        }
                    }
                });

                input.addEventListener('keydown', (e) => {
                    if (e.key === 'Backspace' && e.target.value === '') {
                        const prevInput = document.getElementById(e.target.dataset.prev);
                        if (prevInput) {
                            prevInput.focus();
                        }
                    }
                });

                input.addEventListener('paste', (e) => {
                    const pasteData = e.clipboardData.getData('text');
                    if (pasteData.length === inputs.length) {
                        inputs.forEach((input, i) => {
                            input.value = pasteData[i];
                        });
                        inputs[inputs.length - 1].focus();
                        e.preventDefault();


                        const allFilled = Array.from(inputs).every(input => input.value.trim() !== '');
                        submitButton.disabled = !allFilled;
                    }
                });
            });

            form.addEventListener('submit', function (e) {
                const totpCode = Array.from(inputs).map(input => input.value).join('');
                hiddenInput.value = totpCode;
            });

            const continueButton = document.getElementById("continueButton");
            const backButton = document.getElementById("backButton");
            const codeSetupScreen = document.getElementById("codeSetupScreen");
            const verifyOtpScreen = document.getElementById("verifyOtpScreen");
            const currentScreen = document.getElementById("currentScreen");

            continueButton.addEventListener('click', function () {
                codeSetupScreen.style.display = 'none';
                verifyOtpScreen.style.display = 'block';
                currentScreen.value = "verifyOtpScreen";
            });

            backButton.addEventListener('click', function () {
                verifyOtpScreen.style.display = 'none';
                codeSetupScreen.style.display = 'block';
                currentScreen.value = "codeSetupScreen";
            });

            function showScreen(screenId) {
                if (screenId === "verifyOtpScreen") {
                    codeSetupScreen.style.display = 'none';
                    verifyOtpScreen.style.display = 'block';
                } else {
                    codeSetupScreen.style.display = 'block';
                    verifyOtpScreen.style.display = 'none';
                }
            }

            showScreen(currentScreen.value); // Initialize correct screen on load
        });
    </script>


    <style>

        .code-display {
            background-color: #f8f8f8;
            border-radius: 4px;
            padding: 16px 24px;
            display: inline-block;
            color: #3E3E3E;
            text-align: center;
            margin-bottom: 24px;
        }

        .note {
            color: #999;
            text-align: center;
            font-style: italic;
        }

        .qr-code-container {
            width: 200px;
            height: 200px;
            border: 2px solid #CCCCCC;
            display: flex;
            justify-content: center;
            align-items: center;
            background-color: #fff;
            border-radius: 8px;
        }

        .divider {
            display: flex;
            align-items: center;
            text-align: center;
            width: 100%;
            color: #6C6C6C;
            margin: 2.5rem 0 1.5rem;
        }

            .divider::before,
            .divider::after {
                content: '';
                flex: 1;
                border-bottom: 1px solid #E0E0E0;
                margin: 0 10px;
            }

        .custom-button {
            height: 48px;
        }

        .contact-container {
            background: #E1F2FE;
            border-radius: 4px;
            padding: 20px;
            gap: 12px;
        }

            .contact-container i {
                color: #005CB9;
            }

        .text-container, a {
            color: #00488F;
        }

        .link-button {
            background: none;
            border: none;
            border: 0;
        }
    </style>
}
