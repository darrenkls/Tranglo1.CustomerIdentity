@using Tranglo1.CustomerIdentity.IdentityServer.Models.MFA
@model RedeemRecoveryCodesViewModel

<div class="row vh-100 me-0">
    <div class="col-md-6 d-none d-lg-block ms-0">
        <div class="background-image-tranglo">
            <img src="/assets/images/tranglo-logo-2.svg" class="tranglo-logo" />
            <img src="/assets/images/extra-logo-tranglo-front-screen.svg" class="tranglo-extra-logo" />
        </div>
    </div>
    <div class="col-md d-flex justify-content-center">
        <div class="d-flex align-items-center row w-100">
            <div class="col d-flex justify-content-center">
                <form method="post" name="recoveryCodeForm" id="recoveryCodeForm">
                    <input type="hidden" id="hidden-totp" name="RecoveryCode" asp-for="RecoveryCode">

                    <div>
                        <div class="headline center-container" style="margin-bottom: 2.5rem;">
                            <i class="fa fa-arrow-left me-3" id="backButton" style="cursor: pointer;"></i> Use Recovery code
                        </div>
                        <p class="body-1 center-container" style="margin-bottom: 2rem;">If you are unable to access your two-factor device, enter your recovery code to verify your identity.</p>

                        <div class="center-container">
                            <div class="totp-container">
                                <input autocomplete="off" type="text" maxlength="8" class="totp-input recoveryCode" id="totp-1" data-next="totp-2">
                                <input autocomplete="off" type="text" maxlength="8" class="totp-input recoveryCode" id="totp-2" data-next="totp-3" data-prev="totp-1">
                                <input autocomplete="off" type="text" maxlength="8" class="totp-input recoveryCode" id="totp-3" data-next="totp-4" data-prev="totp-2">
                                <input autocomplete="off" type="text" maxlength="8" class="totp-input recoveryCode" id="totp-4" data-next="totp-5" data-prev="totp-3">
                                <input autocomplete="off" type="text" maxlength="8" class="totp-input recoveryCode" id="totp-5" data-next="totp-6" data-prev="totp-4">
                                <input autocomplete="off" type="text" maxlength="8" class="totp-input recoveryCode" id="totp-6" data-next="totp-7" data-prev="totp-5">
                                <input autocomplete="off" type="text" maxlength="8" class="totp-input recoveryCode" id="totp-7" data-next="totp-8" data-prev="totp-6">
                                <input autocomplete="off" type="text" maxlength="8" class="totp-input recoveryCode" id="totp-8" data-next="totp-9" data-prev="totp-7">
                                <input autocomplete="off" type="text" maxlength="8" class="totp-input recoveryCode" id="totp-9" data-next="totp-10" data-prev="totp-8">
                                <input autocomplete="off" type="text" maxlength="8" class="totp-input recoveryCode" id="totp-10" data-prev="totp-9">
                            </div>

                        </div>

                        <button class="mdc-button button-text w-100 primary-color custom-button" style="margin-top: 2rem;" type="submit" id="submitButton" disabled>
                            <span class="mdc-button__ripple"></span> Verify
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Script {
    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.3/dist/jquery.validate.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const inputs = document.querySelectorAll('.totp-input');
            const hiddenInput = document.getElementById('hidden-totp');
            const submitButton = document.getElementById('submitButton');
            const form = document.getElementById('recoveryCodeForm');

            submitButton.disabled = true;

            // Enable submit button when all fields are filled
            inputs.forEach(input => {
                input.addEventListener('input', function () {
                    const allFilled = Array.from(inputs).every(input => input.value.trim().length === 8);
                    submitButton.disabled = !allFilled;
                });
            });

            // Handle navigation between fields
            inputs.forEach((input, index) => {
                input.addEventListener('input', (e) => {
                    if (e.target.value.length === 8) {
                        const nextInput = document.getElementById(e.target.dataset.next);
                        if (nextInput) {
                            nextInput.focus();
                        }
                    }
                });

                input.addEventListener('keydown', (e) => {
                    if (e.key === 'Backspace' && e.target.value === '') {
                        const prevInput = document.getElementById(e.target.dataset.prev);
                        if (prevInput) {
                            prevInput.focus();
                        }
                    }
                });

                input.addEventListener('paste', (e) => {
                    let pasteData = e.clipboardData.getData('text').replace(/[\s\u00A0]+/g, '');
                    if (pasteData.length === inputs.length * 8) {
                        inputs.forEach((input, i) => {
                            input.value = pasteData.slice(i * 8, (i + 1) * 8);
                        });
                        inputs[inputs.length - 1].focus();
                        e.preventDefault();
                        submitButton.disabled = false;
                    }
                });

                const backButton = document.getElementById("backButton");
                backButton.addEventListener('click', function () {
                    window.location.href = '/Account/LoginWith2fa';
                });

                form.addEventListener('submit', function (e) {
                    const totpCode = Array.from(inputs).map(input => input.value).join(';');
                    hiddenInput.value = totpCode;
                });
            });
        });
    </script>
    <style>
        .totp-container {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            max-width: 100%; /* Allows the container to take full width if needed */
        }

        .totp-input {
            width: calc(20% - 10px); /* Five inputs per row, accounting for the gap */
            height: 57px;
            font-size: 24px;
            text-align: center;
            border: 2px solid #000;
            border-radius: 5px;
            outline: none;
            transition: border-color 0.3s, box-shadow 0.3s;
        }
    </style>
}
