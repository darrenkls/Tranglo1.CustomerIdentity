@using Tranglo1.CustomerIdentity.IdentityServer.Models.MFA
@model ShowRecoveryCodesViewModel

<div class="row vh-100 me-0">
    <div class="col-md-6 d-sm-none d-lg-block ms-0">
        <div class="background-image-tranglo">
            <img src="/assets/images/tranglo-logo-2.svg" class="tranglo-logo" />
            <img src="/assets/images/extra-logo-tranglo-front-screen.svg" class="tranglo-extra-logo" />
        </div>
    </div>
    <div class="col-md d-flex justify-content-center">
        <div class="d-flex align-items-center row w-100">
            <div class="col d-flex justify-content-center flex-column">
                <div class="row" id="recoveryCodeScreen" style="margin-bottom: 100px;">
                    <div class="col">
                        <div class="headline-5 center-container fw-medium" style="margin-bottom: 1.5rem;">
                            Almost there!
                        </div>

                        <div class="body-1 center-container" style="margin-bottom: 1.5rem;">Copy this recovery code and keep it somewhere safe. You’ll need it if you ever need to log in without your device.</div>

                        <div class="body-1 code-display " id="recoveryCode">
                            @for (var row = 0; row < Model.RecoveryCodes.Length; row++)
                            {
                                @Model.RecoveryCodes[row]

                                @if (row < Model.RecoveryCodes.Length - 1)
                                {
                                    <text>&nbsp;</text>
                                }
                            }
                        </div>

                        <div class="center-container cursor:pointer;" style="margin-bottom: 2.5rem;" id="copyButton">
                            <div style="cursor:pointer;">
                                <i class="fa fa-copy me-1"></i> <span style="color: #16BCEF;">Copy code</span>
                            </div>
                        </div>

                        <div class="center-container body-2" style="margin-bottom: 2.5rem;">
                            <label for="recordedNumber"><input type="checkbox" id="recordedNumber" /> I have safely recorded this number</label>
                        </div>

                        <button class="mdc-button button-text w-100 primary-color custom-button" type="button" id="continueButton" disabled>
                            <span class="mdc-button__ripple"></span> Continue
                        </button>
                    </div>
                </div>

                <div class="row" id="successScreen" style="display: none;">
                    <div class="col" style="margin-bottom: 150px;">
                        <div class="center-container" style="margin-bottom: 2rem;">
                            <img src="/assets/images/checkmark.svg" />
                        </div>
                        <div class="headline-5 center-container fw-medium text-center" style="margin-bottom: 2.5rem;">
                            Two-factor authentication(2FA) <br />
                            app enabled!
                        </div>

                        <div class="center-container">
                            <button class="mdc-button w-50 button-text primary-color custom-button" id="closeButton" type="button">
                                <span class="mdc-button__ripple"></span> Continue to login
                            </button>
                        </div>
                    </div>
                </div>

                <partial name="_FooterPartial" />
            </div>
        </div>
    </div>
</div>



@section Script {

    <script src="https://code.jquery.com/jquery-3.5.1.min.js" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.3/dist/jquery.validate.js"></script>
    <script>
        $("#copyButton").click(function () {
            const text = $("#recoveryCode").text(); // Get text from the div

            navigator.clipboard.writeText(text).then(() => {
            }).catch((err) => {
                alert("Failed to copy text");
            });
        });

        $("#recordedNumber").change(function (element) {
            const checked = element.target.checked;
            const continueButton = document.getElementById("continueButton");
            continueButton.disabled = !checked;
        });

        $("#continueButton").click(async function () {
            const recoveryCodeScreen = document.getElementById("recoveryCodeScreen");
            const successScreen = document.getElementById("successScreen");

            recoveryCodeScreen.style.display = "none";
            successScreen.style.display = "block";

            await fetch('@Url.Action("SetupMfaSuccessful", "Account")', { method: 'POST' });
        });

        $("#closeButton").click(function () {
            window.location.href = '@Url.Action("Login", "Account")';
        });
    </script>
    

    <style>
        .center-container {
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .code-display {
            background-color: #f8f8f8;
            border-radius: 4px;
            padding: 17px;
            display: inline-block;
            color: #555;
            text-align: center;
            margin-bottom: 10px;
            white-space: pre-wrap;
            word-break: break-word;
        }

    </style>
}