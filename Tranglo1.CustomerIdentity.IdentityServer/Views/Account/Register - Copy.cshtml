@model RegisterViewModel
@inject Tranglo1.CustomerIdentity.IdentityServer.Services.Recaptcha.RecaptchaKey RecaptchaKey

<div class="row vh-100 me-0">
    <div class="col-md-6 d-sm-none d-lg-block ms-0">
        <div class="background-image-tranglo">
            <img src="/assets/images/tranglo-logo-2.svg" class="tranglo-logo" />
        </div>
    </div>
    <div class="col-md">
        <form method="post" asp-action="Register" asp-controller="Account" name="registration" id="registrationForm" asp-antiforgery="true" novalidate>

            <div class="row mt-3 mb-3">
                <div class="d-flex justify-content-center col">
                    <div class="headline">Create your Tranglo account</div>
                </div>
            </div>

            @*<div class="row">
                <div class="col">
                    @Html.ValidationSummary(false, "", new { @class = "text-danger" })*
                </div>
            </div>*@

            <div class="row">
                <div class="col d-flex justify-content-center">
                    <input type="hidden" asp-for="RecaptchaToken" id="recaptcha-token" />
                    <input type="hidden" asp-for="CustomerTypes" />
                    <div class="mdc-form-field mb-2" id="signUpFormField">
                        <div class="mdc-checkbox" id="signUpCode">
                            <input type="checkbox" class="mdc-checkbox__native-control" id="signUpCodeCheckBox" asp-for="HasSignUpCode" />
                            <div class="mdc-checkbox__background">
                                <svg class="mdc-checkbox__checkmark"
                                     viewBox="0 0 24 24">
                                    <path class="mdc-checkbox__checkmark-path"
                                          fill="none"
                                          d="M1.73,12.91 8.1,19.28 22.79,4.59" />
                                </svg>
                                <div class="mdc-checkbox__mixedmark"></div>
                            </div>
                            <div class="mdc-checkbox__ripple"></div>
                            <div class="mdc-checkbox__focus-ring"></div>
                        </div>
                        <label for="checkbox-1">I have a code</label>
                    </div>
                </div>
            </div>

            <div class="row" id="myDiv" style="display: none;">
                <div class="col">
                    <div class="mb-2 d-flex justify-content-center">
                        <div class="mdc-text-field mdc-text-field--outlined w-100">
                            <input class="mdc-text-field__input" id="registryCode" asp-for="RegistryCode" autocomplete="off">
                            <div class="mdc-notched-outline">
                                <div class="mdc-notched-outline__leading"></div>
                                <div class="mdc-notched-outline__notch">
                                    <label for="username" class="mdc-floating-label">Signup code</label>
                                </div>
                                <div class="mdc-notched-outline__trailing"></div>
                            </div>
                        </div>
                    </div>
                    <br />
                    <div class="d-flex justify-content-center mb-2">
                        <div class="mdc-text-field mdc-text-field--outlined w-100">
                            <input class="mdc-text-field__input" id="fullName" asp-for="FullName" autocomplete="off">
                            <div class="mdc-notched-outline">
                                <div class="mdc-notched-outline__leading"></div>
                                <div class="mdc-notched-outline__notch">
                                    <label for="username" class="mdc-floating-label">Full name</label>
                                </div>
                                <div class="mdc-notched-outline__trailing"></div>
                            </div>
                        </div>
                    </div>
                    <br />
                    <div class="d-flex justify-content-center mb-2">
                        <div class="mdc-text-field mdc-text-field--outlined w-100">
                            <input class="mdc-text-field__input" id="email" asp-for="Email" autocomplete="off">
                            <div class="mdc-notched-outline">
                                <div class="mdc-notched-outline__leading"></div>
                                <div class="mdc-notched-outline__notch">
                                    <label for="username" class="mdc-floating-label">Email</label>
                                </div>
                                <div class="mdc-notched-outline__trailing"></div>
                            </div>
                        </div>
                    </div>
                    <br />
                    <div class="d-flex justify-content-center mb-3">
                        <div class="mdc-text-field mdc-text-field--outlined w-50 me-2">
                            <input class="mdc-text-field__input" id="password" asp-for="Password" autocomplete="off" type="password">
                            <div class="mdc-notched-outline">
                                <div class="mdc-notched-outline__leading"></div>
                                <div class="mdc-notched-outline__notch">
                                    <label for="username" class="mdc-floating-label">Password</label>
                                </div>
                                <div class="mdc-notched-outline__trailing"></div>
                            </div>
                        </div>
                        <div class="mdc-text-field mdc-text-field--outlined w-50">
                            <input class="mdc-text-field__input" id="confirmPassword" asp-for="ConfirmPassword" autocomplete="off" type="password">
                            <div class="mdc-notched-outline">
                                <div class="mdc-notched-outline__leading"></div>
                                <div class="mdc-notched-outline__notch">
                                    <label for="username" class="mdc-floating-label">Confirm password</label>
                                </div>
                                <div class="mdc-notched-outline__trailing"></div>
                            </div>
                        </div>
                    </div>
                    <br />
                    <div class="mdc-form-field mb-2 ">
                        <div class="mdc-checkbox" id="signUpCode">
                            <input type="checkbox" class="mdc-checkbox__native-control" asp-for="IsTermsAndConditionReadAgreed" />
                            <div class="mdc-checkbox__background">
                                <svg class="mdc-checkbox__checkmark"
                                     viewBox="0 0 24 24">
                                    <path class="mdc-checkbox__checkmark-path"
                                          fill="none"
                                          d="M1.73,12.91 8.1,19.28 22.79,4.59" />
                                </svg>
                                <div class="mdc-checkbox__mixedmark"></div>
                            </div>
                            <div class="mdc-checkbox__ripple"></div>
                            <div class="mdc-checkbox__focus-ring"></div>
                        </div>
                        <label for="checkbox-1">
                            By creating an account, you agree to our
                            <a class="text-muted">Privacy &amp; Terms.</a>
                        </label>
                    </div>
                </div>
            </div>

            <div id="solutionChooser">

                <div class="row mt-3 mb-3">
                    <div class="d-flex justify-content-center col-12 mb-2">
                        <div class="body-1">Please select a solution</div>
                    </div>

                    <div class="col-12 d-flex justify-content-evenly">
                        <div class="button-group">
                            <button type="button" id="business" class="mdc-button mdc-button--outlined toggle-button" style="height: 65px;">
                                <span class="mdc-button__ripple"></span>
                                <span class="mdc-button__label">Tranglo Business</span>
                            </button>
                            <button type="button" id="connect" class="mdc-button mdc-button--outlined toggle-button" style="height: 65px;">
                                <span class="mdc-button__ripple"></span>
                                <span class="mdc-button__label">Tranglo Connect</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div id="businessDropdown" style="display: none;">
                <div class="row mb-2">
                    <div class="col-12 d-flex justify-content-center">
                        <div class="mdc-select mdc-select--outlined w-50">
                            <div class="mdc-select__anchor" aria-labelledby="outlined-select-label">
                                <span class="mdc-notched-outline">
                                    <span class="mdc-notched-outline__leading"></span>
                                    <span class="mdc-notched-outline__notch">
                                        <span id="outlined-select-label" class="mdc-floating-label">Solution</span>
                                    </span>
                                    <span class="mdc-notched-outline__trailing"></span>
                                </span>
                                <span class="mdc-select__selected-text-container">
                                    <span id="demo-selected-text" class="mdc-select__selected-text"></span>
                                </span>
                                <span class="mdc-select__dropdown-icon">
                                    <svg class="mdc-select__dropdown-icon-graphic"
                                         viewBox="7 10 10 5" focusable="false">
                                        <polygon class="mdc-select__dropdown-icon-inactive"
                                                 stroke="none"
                                                 fill-rule="evenodd"
                                                 points="7 10 12 15 17 10">
                                        </polygon>
                                        <polygon class="mdc-select__dropdown-icon-active"
                                                 stroke="none"
                                                 fill-rule="evenodd"
                                                 points="7 15 12 10 17 15">
                                        </polygon>
                                    </svg>
                                </span>
                            </div>

                            <!-- Other elements from the select remain. -->
                            <div class="mdc-select__menu mdc-menu mdc-menu-surface w-100">
                                <ul class="mdc-deprecated-list">
                                    @foreach (var type in Model.CustomerTypes)
                                    {
                                        <li class="mdc-deprecated-list-item" data-value="@type.CustomerTypeCode">
                                            <span class="mdc-deprecated-list-item__ripple"></span>
                                            <span class="mdc-deprecated-list-item__text">@type.Description</span>
                                        </li>
                                    }
                                </ul>
                            </div>

                        </div>

                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col d-flex justify-content-center">
                    <!--<button class="mdc-button g-recaptcha button-text w-75 primary-color custom-button" id="registerBtn" data-sitekey="@RecaptchaKey.SiteKey"
                            data-callback='onSubmit'
                            data-action='submit' type="submit">
                        <span class="mdc-button__ripple"></span> Create account
                    </button>-->
                    <button data-sitekey="@RecaptchaKey.SiteKey"
                            data-callback='onSubmit'
                            data-action='submit'
                            type="button">Create account</button>
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-12 text-center">
                    <p class="text-muted">
                        Already have account? <a asp-controller="Account" asp-action="Login" class="text-muted ml-1"><b>Login</b></a>
                    </p>
                </div>
            </div>
        </form>

    </div>
</div>

@section styles {
<style>
    .mdc-select__menu {
        z-index: 99999999999 !important; /* set a high z-index value */
    }
</style>
    
}

@section Script{
    <script src="https://code.jquery.com/jquery-3.5.1.min.js" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.3/dist/jquery.validate.js"></script>
    <script src="https://www.google.com/recaptcha/api.js"></script>
    <script src="/assets/js/tranglo1/password-validation.js" asp-append-version="true"></script>
    <script src="/assets/js/tranglo1/registration-form-validation.js" asp-append-version="true"></script>
    <script>

//var defaultUserType = 1;

grecaptcha.ready(function () {
            registerButtonDisabled(false);
        });

        function registerButtonDisabled(disabled) {
            $('#registerBtn').prop('disabled', disabled);
        }

        function onSubmit(token) {
            document.getElementById("recaptcha-token").setAttribute("value", token);
            document.getElementById("registrationForm").submit();
        }

        $('document').ready(function () {

            let checkbox = document.getElementById('signUpCodeCheckBox');

            initForm()

            checkbox.addEventListener('click', () => {
                if (checkbox.checked) {
                    $("#myDiv").addClass("show").removeClass("hide").show();
                    $("#solutionChooser").addClass("hide").removeClass("show").hide();
                    $('.button-group .toggle-button').removeClass('active-toggle');
                    $("#businessDropdown").addClass("hide").removeClass("show").hide();
                } else {
                    $("#myDiv").addClass("hide").removeClass("show");
                    setTimeout(function () {
                        $("#myDiv").hide();
                    }, 300);
                    $("#solutionChooser").addClass("show").removeClass("hide").show();
                }
            });

            [].forEach.call(document.querySelectorAll('.mdc-text-field'), function (el) {
                mdc.textField.MDCTextField.attachTo(el);
            });

            [].forEach.call(document.querySelectorAll('.mdc-form-field'), function (el) {
                mdc.formField.MDCFormField.attachTo(el);
            });

            [].forEach.call(document.querySelectorAll('.mdc-checkbox'), function (el) {
                mdc.checkbox.MDCCheckbox.attachTo(el);
            });

            const select = mdc.select.MDCSelect.attachTo(document.querySelector('.mdc-select'));
            select.listen('MDCSelect:change', () => {
                $('input[name="CustomerTypes"]').val(select.value);
                console.log($('input[name="CustomerTypes"]').attr('value'));
                
            });

            $('.button-group .toggle-button').click(function () {
                $('.button-group .toggle-button').removeClass('active-toggle');
                var buttonId = $(this).attr('id');
                $(this).addClass('active-toggle');

                switch (buttonId) {
                    case "business": {
                        $("#businessDropdown").addClass("show").removeClass("hide").show();
                        break;
                    }
                    case "connect": {
                        $("#businessDropdown").addClass("hide").removeClass("show").hide();
                        //$("#solutionChooser").addClass("show").removeClass("hide").show();
                        break;
                    }
                }
            });

            $('.input-validation-error').addClass('is-invalid')

            //$("#companyName, #name, #email, #passwordField, #IsTermsAndConditionReadAgreed").on('input', function () {
            //    if (isValidForm()) {
            //        registerButtonDisabled(false);
            //    } else {
            //        registerButtonDisabled(true);
            //    }
            //});
        });


        //$('#userTypeDropdown').on('change', function () {
        //    if ($('#userTypeDropdown').val() != "1") {
        //        $('#solutionDropdown').show();
        //    } else {
        //        $('#solutionDropdown').hide();
        //    }
        //});

        $('#passwordField').on('input', function () {
            var err = validatePassword($('#passwordField').val()).Errors || [];

            document.getElementById('passwordError').innerHTML = err.join('<br/>');

            if (validatePassword($('#passwordField').val()).ContainError == true) {
                $('#passwordErrorbool').show();
                $('#passwordFeedback').hide();
                passwordInputFailed();
            }
            else {
                $('#passwordErrorbool').hide();
                $('#passwordFeedback').show();
                passwordInputSuccess();
            }
        });

                function initForm() {
                    let checkbox = document.getElementById('signUpCodeCheckBox');



                        if (checkbox.checked) {
                            $("#myDiv").addClass("show").removeClass("hide").show();
                            $("#solutionChooser").addClass("hide").removeClass("show").hide();
                            $('.button-group .toggle-button').removeClass('active-toggle');
                            $("#businessDropdown").addClass("hide").removeClass("show").hide();
                        } else {
                            $("#myDiv").addClass("hide").removeClass("show");
                            setTimeout(function () {
                                $("#myDiv").hide();
                            }, 300);
                            $("#solutionChooser").addClass("show").removeClass("hide").show();
                        }
                }

        function isValidForm() {
            const companyName = $('#companyName').val();
            const name = $('#name').val();
            const email = $('#email').val();
            const country = $('#country').val();
            const password = $('#passwordField').val();
            const isChecked = $('#IsTermsAndConditionReadAgreed')[0].checked;

            if (companyName.length > 0 && name.length > 0 && email.length > 0 && country.length > 0 && password.length > 0 && isChecked == true) {
                return true;
            }
            else {
                return false;
            }

        }

        $('#name, #companyName').bind('keypress', function (event) {
            var code = event.key;
            if (!(/^[a-zA-Z0-9 ]*$/g).test(code)) {
                event.preventDefault()
            }
        })

    </script>

}
