@model RegisterWithRegistryCodeViewModel
@inject Tranglo1.CustomerIdentity.IdentityServer.Services.Recaptcha.RecaptchaKey RecaptchaKey

<div class="account-pages mt-5 mb-5">
	<div class="container">
		<div class="row justify-content-center">
			<div class="col-lg-5">
				<div class="card">
					<!-- Logo-->
					<div class="card-header pt-4 pb-4 text-center bg-primary">
						<a href="/">
							<span><img src="/assets/images/logo.png" alt="" height="18"></span>
						</a>
					</div>
					<form method="post" asp-action="RegisterWithRegistryCode" asp-controller="Account" name="registrationWithRegistryCode" id="registrationWithRegistryCodeForm" asp-antiforgery="true" class="needs-validation" novalidate>
						<div class="card-body p-4">

							<input type="hidden" asp-for="RecaptchaToken" id="recaptcha-token" />

							<div class="text-center w-75 m-auto">
								<h4 class="text-dark-50 text-center mt-0 font-weight-bold">Tranglo Sign Up</h4>
								<p class="text-muted mb-4">Please fill out the form below.</p>
							</div>

							@*@Html.ValidationSummary(false, "", new { @class = "text-danger" })*@

                        <div class="form-group mb-3">
                            <label asp-for="RegistryCode">Registry Code</label>
                            <input type="text" class="form-control" placeholder="Enter your registry code" asp-for="RegistryCode" id="registryCode" />
                            <div id="registryCodeFeedback"><span asp-validation-for="RegistryCode" class="text-danger"></span></div>
                        </div>

							<div class="form-group mb-3">
								<label asp-for="FullName">Name (P-I-C)</label>
								<input type="text" class="form-control" placeholder="Enter your name" asp-for="FullName" id="name" />
								<div id="nameFeedback"></div>
							</div>

							<div class="form-group mb-3">
								<label asp-for="Email">Email Address</label>
								<input type="email" class="form-control" placeholder="Enter your email" asp-for="Email" id="email" />                                
								<div id="emailFeedback"><span asp-validation-for="Email" class="text-danger"></span></div>
							</div>

							<div class="form-group mb-3">
								<label asp-for="Password">Password</label>
								<div class="input-group input-group-merge">
									<input type="password" asp-for="Password" class="form-control" placeholder="Enter your password" id="passwordField">
									<div class="input-group-append" data-password="false">
										<div class="input-group-text">
											<span class="password-eye"></span>
										</div>
									</div>
								</div>
								<span id="passwordErrorbool" class="text-danger" style="display:none" ;></span>
								<span id="passwordError" class="text-danger"></span>
								<div id="passwordFeedback"></div>
							</div>

							<div class="form-group mb-3">
								<div class="custom-control custom-checkbox" id="TOCParent">
									<input asp-for="IsTermsAndConditionReadAgreed" class="custom-control-input">
									<label asp-for="IsTermsAndConditionReadAgreed" class="custom-control-label">
										Please read and agree to
										<a class="text-muted" data-toggle="modal" data-target="#scrollable-modal">Terms and Conditions</a>
										to proceed.
									</label>
								</div>
								<span id="TOCfeedback"></span>
							</div>

							<div class="form-group mb-0 text-center">
								<button class="btn btn-primary g-recaptcha"
										data-sitekey="@RecaptchaKey.SiteKey"
										data-callback='onSubmit'
										data-action='submit'
										id="registerBtn">
									Sign Up
								</button>
							</div>

						</div>
					</form>
				</div>

				<div class="row mt-3">
					<div class="col-12 text-center">
						<p class="text-muted">
							Already have account? <a asp-controller="Account" asp-action="Login" class="text-muted ml-1"><b>Log In</b></a>
						</p>
					</div>
				</div>

			</div>
		</div>
		<!-- end row -->
	</div>
	<!-- end container -->
</div>
<!-- end page -->

<div class="modal fade" id="scrollable-modal" tabindex="-1" role="dialog"
	 aria-labelledby="scrollableModalTitle" aria-hidden="true">
	<div class="modal-dialog modal-dialog-scrollable modal-lg" role="document">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title" id="scrollableModalTitle">Terms and Conditions</h5>
				<button type="button" class="close" data-dismiss="modal" aria-label="Close">
					<span aria-hidden="true">&times;</span>
				</button>
			</div>
			<div class="modal-body">
				<partial name="_TermsAndConditions" />
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
			</div>
		</div><!-- /.modal-content -->
	</div><!-- /.modal-dialog -->
</div><!-- /.modal -->


@section Script {
	<script src="https://code.jquery.com/jquery-3.5.1.min.js" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous"></script>
	<script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.3/dist/jquery.validate.js"></script>
	<script src="https://www.google.com/recaptcha/api.js"></script>
	<script src="/assets/js/tranglo1/password-validation.js" asp-append-version="true"></script>
	<script src="/assets/js/tranglo1/registration-form-validation.js" asp-append-version="true"></script>
	<script>
        var registryCodeString = $('#registryCode').val();
		grecaptcha.ready(function () {
			registerButtonDisabled(true);
		});

		function registerButtonDisabled(disabled) {
			$('#registerBtn').prop('disabled', disabled);
		}

		function onSubmit(token) {
			document.getElementById("recaptcha-token").setAttribute("value", token);
			document.getElementById("registrationWithRegistryCodeForm").submit();
		}

		$('document').ready(function () {
            $('.input-validation-error').addClass('is-invalid')
			$("#registryCode, #name, #email, #passwordField, #IsTermsAndConditionReadAgreed").on('input', function () {
				if (isValidForm()) {
					registerButtonDisabled(false);
				} else {
					registerButtonDisabled(true);
				}
			});
		});

		$('#passwordField').on('input', function () {
			var err = validatePassword($('#passwordField').val()).Errors || [];


			document.getElementById('passwordError').innerHTML = err.join('<br/>');

			if (validatePassword($('#passwordField').val()).ContainError == true) {
				$('#passwordErrorbool').show();
				$('#passwordFeedback').hide();
				passwordInputFailed();
			}
			else {
				$('#passwordErrorbool').hide();
				$('#passwordFeedback').show();
				passwordInputSuccess();
			}
		});

		function isValidForm() {
			const registryCode = $('#registryCode').val();
			const name = $('#name').val();
			const email = $('#email').val();
			const password = $('#passwordField').val();
			const isChecked = $('#IsTermsAndConditionReadAgreed')[0].checked;

            registryCodeString = registryCode

			if (registryCode.length > 0 && name.length > 0 && email.length > 0 && password.length > 0 && isChecked == true) {
				return true;
			}
			else {
				return false;
			}

		}

		$('#name').bind('keypress', function (event) {
			var code = event.key;
			if (!(/^[a-zA-Z0-9 ]*$/g).test(code)) {
				event.preventDefault()
			}
		})

	</script>

}
