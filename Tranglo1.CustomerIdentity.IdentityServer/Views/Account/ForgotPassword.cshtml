
@model ForgotPasswordModel

<div class="row vh-100 me-0">
    <div class="col-md-6 d-sm-none d-xs-none d-lg-block ms-0">
        <div class="background-image-tranglo">
            <img src="/assets/images/tranglo-logo-2.svg" class="tranglo-logo" />
            <img src="/assets/images/extra-logo-tranglo-front-screen.svg" class="tranglo-extra-logo" />
        </div>
    </div>

    <div class="col d-flex flex-column justify-content-center align-items-center" style="max-height: 100vh; overflow: auto;">
        <div class="col-8 mx-auto">
            <div class="d-flex flex-column">
                <h4 class="text-dark-50 text-center headline mt-3">Reset your Password</h4>
                <p class="text-muted mt-3 mb-4 text-center subtitle-2">Enter your login email and we will send you instructions on resetting your password.</p>
            </div>

            @{ bool showEmailFieldGroup = true; }

            @{

                if (ViewData.ModelState.IsValid == false)
                {
                    <div class="alert alert-danger" role="alert" id="ErrorAlert">

                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            foreach (var error in modelState.Errors)
                            {
                                @error.ErrorMessage
                            }
                        }

                    </div>
                }
            }

            @{

                if (ViewData["ForgotPassword.Success"] != null)
                {
                    showEmailFieldGroup = false;

                    <div class="alert alert-success" role="alert" id="SuccessAlert">
                        @ViewData["ForgotPassword.Success"]
                    </div>
                }

            }

            <form asp-controller="Account" asp-action="ForgotPassword">
                @{
                    if (showEmailFieldGroup)
                    {
                        <div class="row">
                            <div class="col d-flex justify-content-center">
                                <div class="mdc-text-field mdc-text-field--outlined w-100">
                                    <input class="mdc-text-field__input" id="emailaddress" type="email" autocomplete="off" placeholder="Enter your email" name="Email" asp-for="Email">
                                    <div class="mdc-notched-outline">
                                        <div class="mdc-notched-outline__leading"></div>
                                        <div class="mdc-notched-outline__notch">
                                            <label for="email" class="mdc-floating-label">Email Address</label>
                                        </div>
                                        <div class="mdc-notched-outline__trailing"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4 text-center">
                            <button class="mdc-button button-text w-100 primary-color   custom-button" id="reset-password-button" type="submit">
                                <span class="mdc-button__ripple"></span> Proceed
                            </button>
                        </div>
                    }
                }
            </form>
        </div>

        @* Return to login *@
        <div class="row mt-3">
            <div class="col-12 text-center">
                <a asp-controller="Account" asp-action="Login" class="subtitle-2 link-text"><b>Return to login</b></a>
            </div>
        </div>

        @* Footer *@
        <div class="row d-flex justify-content-center">
            <div class="col">
                <partial name="_FooterPartial" />
            </div>
        </div>
    </div>
</div>

@section script {
    <script src="https://code.jquery.com/jquery-3.5.1.min.js"
            integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0="
            crossorigin="anonymous"></script>

    <script>

        function disableResetPasswordButton(disabled) {
            var $resetButton = $('#reset-password-button');

            if (disabled) {
                $resetButton.attr('disabled', true);
                $resetButton.addClass('opacity-25');
            } else {
                $resetButton.attr('disabled', false);
                $resetButton.removeClass('opacity-25');
            }
        }

        function validateEmail(emailString) {
            var mailformat = /^[a-zA-Z0-9.!#$%&'*+/=?^_`{|}~-]+@@[a-zA-Z0-9-]+(?:\.[a-zA-Z0-9-]+)*$/;

            if (emailString.match(mailformat)) {
                return true;
            } else {
                return false;
            }
        }

        $(document).ready(function () {
            disableResetPasswordButton(true);

            $('#emailaddress').on('input', function () {
                const emailAddress = $('#emailaddress').val();

                if (validateEmail(emailAddress)) {
                    disableResetPasswordButton(false);
                } else {
                    disableResetPasswordButton(true);
                }
            });

            [].forEach.call(document.querySelectorAll('.mdc-text-field'), function (el) {
                mdc.textField.MDCTextField.attachTo(el);
            });
        });
    </script>
} 